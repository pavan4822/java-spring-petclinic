pipeline {
    agent {label 'pavan-scp-project'}
    
     triggers {
        pollSCM('* * * * *')
    }

    stages {
        stage('Clone Code') {
           steps {
               git branch: 'main',
               url: 'https://github.com/pavan4822/java-spring-petclinic.git'
    }
}

        stage('SonarCloud Scan') {
            steps {
                withSonarQubeEnv('sonarcloud') {
                    sh '''
                    -Dsonar.projectKey=java-spring-petclinic \
                    -Dsonar.organization=pavan4822 \
                    -Dsonar.host.url=https://sonarcloud.io \
                    -Dsonar.login=$sonar-id
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }
}